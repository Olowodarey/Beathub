# Copy the value here into backend/.env (which was auto-created by `prisma init`
# and is gitignored). Replace the placeholder DATABASE_URL there with your real
# Neon connection string. Do NOT commit backend/.env.

# Neon connection string. Format:
#   postgresql://<user>:<password>@<host>/<db>?sslmode=require
# Neon dashboard → your project → "Connection string" (Prisma / pooled)
DATABASE_URL="postgresql://user:password@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require"

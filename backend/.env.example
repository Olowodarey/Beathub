# Copy the value here into backend/.env (which was auto-created by `prisma init`
# and is gitignored). Replace the placeholder DATABASE_URL there with your real
# Neon connection string. Do NOT commit backend/.env.

# Neon connection string. Format:
#   postgresql://<user>:<password>@<host>/<db>?sslmode=require
# Neon dashboard → your project → "Connection string" (Prisma / pooled)
DATABASE_URL="postgresql://user:password@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require"

# Secret used to sign session JWTs. Use a long random string, e.g.
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
AUTH_JWT_SECRET="change-me-to-a-long-random-string"

# Google OAuth Client ID from Google Cloud Console (APIs & Services → Credentials).
# Same value goes in the frontend as NEXT_PUBLIC_GOOGLE_CLIENT_ID.


# Email that should be granted the OWNER role on first sign-in (optional).
OWNER_EMAIL="you@example.com"

# Comma-separated allowed frontend origins for CORS.
FRONTEND_ORIGIN="http://localhost:3000"

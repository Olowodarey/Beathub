// Prisma schema for Beathub backend.
// Datasource URL is resolved via prisma.config.ts (reads DATABASE_URL from .env).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  OWNER
  ADMIN
  MEMBER
}

enum PersonaType {
  LISTENER
  CREATOR
  LABEL_REP
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PlaylistInviteStatus {
  PENDING
  ACCEPTED
  DECLINED
  REVOKED
}

enum LabelInviteStatus {
  PENDING
  ACCEPTED
  DECLINED
  REVOKED
}

enum UserStatus {
  ACTIVE
  INVITED
  SUSPENDED
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

enum ContentKind {
  TRACK
  PODCAST
}

enum ContentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AdSlotType {
  HOMEPAGE_FEATURED
  GENRE_SPOTLIGHT
  PLAYLIST_PLACEMENT
}

enum CampaignStatus {
  PENDING
  APPROVED
  REJECTED
  ACTIVE
  ENDED
}

model User {
  id             String     @id @default(cuid())
  email          String     @unique
  passwordHash   String?
  googleId       String?    @unique
  name           String?
  avatarUrl      String?
  status         UserStatus @default(ACTIVE)
  createdAt      DateTime   @default(now())
  signedLabelId  String?

  memberships          Membership[]
  uploadedContent      Content[]            @relation("ContentUploader")
  campaignsCreated     AdCampaign[]         @relation("CampaignRequester")
  campaignsReviewed    AdCampaign[]         @relation("CampaignReviewer")
  invitationsSent      Invitation[]         @relation("InvitationInviter")
  creatorApplications  CreatorApplication[] @relation("CreatorApplicant")
  creatorAppsReviewed  CreatorApplication[] @relation("CreatorApplicationReviewer")
  playlistsOwned       Playlist[]           @relation("PlaylistOwner")
  playlistMemberships  PlaylistMember[]     @relation("PlaylistMember")
  playlistTracksAdded  PlaylistTrack[]      @relation("PlaylistTrackAdder")
  playlistInvitesSent  PlaylistInvite[]     @relation("PlaylistInviteInviter")
  playlistInvitesGot   PlaylistInvite[]     @relation("PlaylistInviteInvitee")
  labelApplications    LabelApplication[]   @relation("LabelApplicant")
  labelAppsReviewed    LabelApplication[]   @relation("LabelApplicationReviewer")
  labelInvitesSent     LabelInvite[]        @relation("LabelInviter")
  labelInvitesGot      LabelInvite[]        @relation("LabelInvitee")
  signedLabel          User?                @relation("LabelRoster", fields: [signedLabelId], references: [id], onDelete: SetNull)
  signedArtists        User[]               @relation("LabelRoster")

  @@index([signedLabelId])
}

model Team {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  logoUrl   String?
  createdAt DateTime @default(now())

  memberships         Membership[]
  invitations         Invitation[]
  campaigns           AdCampaign[]
  content             Content[]
  creatorApplications CreatorApplication[]
  labelApplications   LabelApplication[]
}

model Membership {
  id          String       @id @default(cuid())
  userId      String
  teamId      String
  role        Role
  personaType PersonaType?
  createdAt   DateTime     @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([userId, teamId])
  @@index([teamId])
}

model Invitation {
  id          String           @id @default(cuid())
  email       String
  teamId      String
  role        Role
  personaType PersonaType?
  status      InvitationStatus @default(PENDING)
  token       String           @unique
  invitedById String
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime         @default(now())

  team      Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  invitedBy User @relation("InvitationInviter", fields: [invitedById], references: [id])

  @@index([teamId])
  @@index([email])
}

model Content {
  id              String        @id @default(cuid())
  teamId          String
  kind            ContentKind
  title           String
  uploaderId      String
  durationSeconds Int
  genre           String
  status          ContentStatus @default(PENDING)
  audioUrl        String?
  audioMimeType   String?
  fileSizeBytes   Int?
  playCount       Int           @default(0)
  createdAt       DateTime      @default(now())

  team            Team            @relation(fields: [teamId], references: [id], onDelete: Cascade)
  uploader        User            @relation("ContentUploader", fields: [uploaderId], references: [id])
  playlistEntries PlaylistTrack[]

  @@index([teamId])
  @@index([status])
}

model Playlist {
  id        String   @id @default(cuid())
  name      String
  ownerId   String
  createdAt DateTime @default(now())

  owner   User             @relation("PlaylistOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  tracks  PlaylistTrack[]
  members PlaylistMember[]
  invites PlaylistInvite[]

  @@index([ownerId])
}

model PlaylistInvite {
  id          String               @id @default(cuid())
  playlistId  String
  invitedById String
  inviteeId   String
  status      PlaylistInviteStatus @default(PENDING)
  createdAt   DateTime             @default(now())
  decidedAt   DateTime?

  playlist  Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  invitedBy User     @relation("PlaylistInviteInviter", fields: [invitedById], references: [id])
  invitee   User     @relation("PlaylistInviteInvitee", fields: [inviteeId], references: [id], onDelete: Cascade)

  @@index([inviteeId, status])
  @@index([playlistId, status])
}

model PlaylistTrack {
  id         String   @id @default(cuid())
  playlistId String
  contentId  String
  addedById  String
  position   Int      @default(0)
  createdAt  DateTime @default(now())

  playlist Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  content  Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)
  addedBy  User     @relation("PlaylistTrackAdder", fields: [addedById], references: [id])

  @@unique([playlistId, contentId])
  @@index([playlistId])
}

model PlaylistMember {
  id         String   @id @default(cuid())
  playlistId String
  userId     String
  addedAt    DateTime @default(now())

  playlist Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  user     User     @relation("PlaylistMember", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([playlistId, userId])
  @@index([userId])
}

model LabelApplication {
  id           String            @id @default(cuid())
  userId       String
  teamId       String
  labelName    String?
  message      String?
  status       ApplicationStatus @default(PENDING)
  reviewerId   String?
  reviewerNote String?
  createdAt    DateTime          @default(now())
  decidedAt    DateTime?

  user     User  @relation("LabelApplicant", fields: [userId], references: [id], onDelete: Cascade)
  team     Team  @relation(fields: [teamId], references: [id], onDelete: Cascade)
  reviewer User? @relation("LabelApplicationReviewer", fields: [reviewerId], references: [id])

  @@index([teamId, status])
  @@index([userId])
}

model LabelInvite {
  id           String            @id @default(cuid())
  labelUserId  String
  artistUserId String
  status       LabelInviteStatus @default(PENDING)
  createdAt    DateTime          @default(now())
  decidedAt    DateTime?

  label  User @relation("LabelInviter", fields: [labelUserId], references: [id], onDelete: Cascade)
  artist User @relation("LabelInvitee", fields: [artistUserId], references: [id], onDelete: Cascade)

  @@index([artistUserId, status])
  @@index([labelUserId, status])
}

model CreatorApplication {
  id           String            @id @default(cuid())
  userId       String
  teamId       String
  message      String?
  status       ApplicationStatus @default(PENDING)
  reviewerId   String?
  reviewerNote String?
  createdAt    DateTime          @default(now())
  decidedAt    DateTime?

  user     User  @relation("CreatorApplicant", fields: [userId], references: [id], onDelete: Cascade)
  team     Team  @relation(fields: [teamId], references: [id], onDelete: Cascade)
  reviewer User? @relation("CreatorApplicationReviewer", fields: [reviewerId], references: [id])

  @@index([teamId, status])
  @@index([userId])
}

model AdCampaign {
  id           String         @id @default(cuid())
  teamId       String
  requesterId  String
  slotType     AdSlotType
  budgetUsd    Int
  startDate    DateTime
  endDate      DateTime
  status       CampaignStatus @default(PENDING)
  reviewerId   String?
  reviewerNote String?
  impressions  Int?
  clicks       Int?
  createdAt   DateTime        @default(now())

  team      Team  @relation(fields: [teamId], references: [id], onDelete: Cascade)
  requester User  @relation("CampaignRequester", fields: [requesterId], references: [id])
  reviewer  User? @relation("CampaignReviewer", fields: [reviewerId], references: [id])

  @@index([teamId])
  @@index([status])
}
